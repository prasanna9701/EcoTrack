{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "experimentalDecorators": true
  },
  "include": ["smart_contracts/**/*.ts", "smart_contracts/**/*.algo.ts"],
  "exclude": ["node_modules", "dist"]
}
