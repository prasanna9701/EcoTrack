{
  "scripts": {},
  "files": [
    "**"
  ],
  "name": "@algorandfoundation/algorand-typescript",
  "version": "1.1.0",
  "description": "This package contains definitions for the types which comprise Algorand TypeScript which can be compiled to run on the Algorand Virtual Machine using the Puya compiler.",
  "private": false,
  "overrides": {},
  "peerDependencies": {
    "tslib": "^2.6.2"
  },
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./arc4": {
      "types": "./arc4/index.d.ts",
      "import": "./arc4/index.mjs",
      "require": "./arc4/index.js"
    },
    "./op": {
      "types": "./op.d.ts",
      "import": "./op.mjs",
      "require": "./op.js"
    }
  }
}
